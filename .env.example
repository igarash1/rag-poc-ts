# Copy to .env and set ONE provider key. With no key the app runs in MOCK mode
# (deterministic fake embeddings + templated answers) so the full pipeline is
# testable offline with zero API cost.
#
# Provider is auto-detected: a Gemini key -> gemini, else an OpenAI key -> openai.
GEMINI_API_KEY=
# OPENAI_API_KEY=

# Optional overrides
# RAG_PROVIDER=gemini          # force a provider (gemini | openai | mock)
# CHAT_MODEL=gemini-2.5-flash
# EMBED_MODEL=text-embedding-004
# RAG_MOCK=1                   # force mock mode even if a key is present
